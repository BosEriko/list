{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next",
      },
    ],
    "paths": {
      "@/*": ["./*"],
      "@constant/*": ["./config/initializers/constant/*"],
      "@lib/*": ["./lib/*"],
      "@schema": ["./db/schema"],
      "@store/*": ["./app/(services)/store/*"],

      "@model/*": ["./app/(model)/*"],
      "@view/*": ["./app/(view)/*"],
      "@controller/*": ["./app/(controller)/*"],

      "@atom": ["./app/(view)/atoms"],
      "@molecule": ["./app/(view)/molecules"],
      "@organism": ["./app/(view)/organisms"],
      "@template": ["./app/(view)/templates"],

      // TODO: Remove when not in use anymore
      "@old-model/*": ["./model/*"],
    },
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
  ],
  "exclude": ["node_modules"],
}
