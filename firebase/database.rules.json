{
  "rules": {
    "posts": {
      ".read": "auth != null",
      "$postId": {
        ".read": "auth != null",
        ".write": "auth != null",

        "uid": {
          ".validate": "newData.val() === auth.uid"
        },

        "displayName": {
          ".validate": "newData.val() === auth.token.name"
        },

        "photoURL": {
          ".validate": "newData.val() === auth.token.picture"
        },

        "content": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },

        "createdAt": {
          ".validate": "newData.isNumber()"
        }
      }
    }
  }
}
