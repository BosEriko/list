rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /listings/{listingId} {
      function validListingId(id) {
        return id.matches('^' + request.auth.uid + '-[a-zA-Z0-9_-]+-[a-zA-Z0-9_-]+$');
      }
      function validCreatedAt() {
        return (
          ("createdAt" in resource.data && request.resource.data.createdAt == resource.data.createdAt) || !("createdAt" in resource.data) && request.resource.data.createdAt == request.resource.data.updatedAt
        );
      }
      function getItem() {
        return get(/databases/$(database)/documents/items/$(request.resource.data.type + "-" + request.resource.data.itemId));
      }
      function validCount() {
        let item = getItem();
        let total = item.data.totalCount;
        return item.data != null && request.resource.data.count is int && request.resource.data.count >= 0 && (item.data.totalCount == null || request.resource.data.count <= item.data.totalCount);
      }
      function validStatus() {
        let item = getItem();
        return item.data != null && (item.data.totalCount == null || request.resource.data.count != item.data.totalCount || request.resource.data.status == 3);
      }
      allow read:   if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && validListingId(listingId)
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.updatedAt is timestamp
                    && validCount()
                    && validStatus();
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && validListingId(listingId)
                    && validCreatedAt()
                    && request.resource.data.updatedAt is timestamp
                    && validCount()
                    && validStatus();
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && validListingId(listingId);
    }
  }
}
