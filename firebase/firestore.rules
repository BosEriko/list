rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ========================================================================================== //
    // Helper functions                                                                           //
    // ========================================================================================== //
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && userId == request.auth.uid;
    }
    function validCreatedAt(createdAt) {
      return ("createdAt" in resource.data) ? createdAt == resource.data.createdAt : createdAt == request.time;
    }
    // ========================================================================================== //
    // Listings Collection                                                                        //
    // ========================================================================================== //
    match /listings/{listingId} {
      function validListingId(id) {
        return id.matches('^' + request.auth.uid + '-[a-zA-Z0-9_-]+-[a-zA-Z0-9_-]+$');
      }
      function getItem() {
        return get(/databases/$(database)/documents/items/$(request.resource.data.type + "-" + request.resource.data.itemId));
      }
      function validCount() {
        let item = getItem();
        let total = item.data.totalCount;
        return item.data != null && request.resource.data.count is int && request.resource.data.count >= 0 && (item.data.totalCount == null || request.resource.data.count <= item.data.totalCount);
      }
      function validStatus() {
        let item = getItem();
        return item.data != null && (item.data.totalCount == null || request.resource.data.count != item.data.totalCount || request.resource.data.status == 3);
      }
      allow read:   if true;
      allow create: if isOwner(request.resource.data.userId)
                    && validListingId(listingId)
                    && request.resource.data.updatedAt is timestamp
                    && validCreatedAt(request.resource.data.createdAt)
                    && validCount()
                    && validStatus();
      allow update: if isOwner(resource.data.userId)
                    && validListingId(listingId)
                    && validCreatedAt(request.resource.data.createdAt)
                    && request.resource.data.updatedAt is timestamp
                    && validCount()
                    && validStatus();
      allow delete: if isOwner(resource.data.userId);
    }
    // ========================================================================================== //
    // Global Collection                                                                          //
    // ========================================================================================== //
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
